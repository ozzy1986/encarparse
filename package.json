{
  "name": "encarparse",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "ENCAR scraper and landing page.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 3000",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "playwright:install": "playwright install chromium",
    "inspect:encar": "tsx scripts/inspect-encar.ts",
    "scrape:encar": "tsx scripts/scrape-encar.ts",
    "scrape:encar:headful": "tsx scripts/scrape-encar.ts --headful",
    "deploy:vps": "bash scripts/deploy-vps.sh",
    "bootstrap:vps": "bash scripts/bootstrap-vps.sh",
    "postinstall": "prisma generate"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "lucide-react": "^1.7.0",
    "next": "^16.2.1",
    "pg": "^8.16.3",
    "playwright": "^1.58.2",
    "prisma": "^7.6.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
